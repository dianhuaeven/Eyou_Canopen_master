<launch>
  <!--
    ROS launch skeleton for canopen_hw node.
    NOTE: commit 10 only adds structure; ROS integration will be completed later.
  -->
  <node pkg="canopen_hw"
        type="canopen_hw_node"
        name="canopen_hw"
        output="screen">
    <param name="can_interface" value="can0" />
    <param name="master_dcf" value="$(find canopen_hw)/config/master.dcf" />
    <param name="joints_yaml" value="$(find canopen_hw)/config/joints.yaml" />
  </node>
</launch>
